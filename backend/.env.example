# ══════════════════════════════════════════════════
# 后端环境变量示例
# 用法：复制本文件为 .env，填入真实值。.env 不要提交到 git。
# ══════════════════════════════════════════════════

# ── 数据库连接串 ──
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# 开发期用腾讯云 PostgreSQL 的【外网地址】+ beile_dev 库
# 上线换成【内网地址】+ beile_prod 库
DATABASE_URL=postgresql+asyncpg://root:请填数据库密码@请填外网host:5432/beile_dev

# ── JWT 配置 ──
# JWT_SECRET 随便一串足够长的随机字符串（自己生成，保密！可用命令 openssl rand -hex 32 生成）
JWT_SECRET=请换成一段很长的随机字符串
JWT_EXPIRE_DAYS=7

# ── 腾讯云短信（手机 OTP）──
# 从腾讯云控制台「访问管理 - API密钥管理」获取
TENCENT_SECRET_ID=请填
TENCENT_SECRET_KEY=请填
# 从「短信 SMS」控制台获取
SMS_SDK_APP_ID=请填应用ID
SMS_SIGN_NAME=请填已审核通过的签名内容
SMS_TEMPLATE_ID=请填已审核通过的模板ID
# 短信服务地域，一般 ap-guangzhou
SMS_REGION=ap-guangzhou

# ── 开发模式开关 ──
# true = 不真发短信，验证码固定为 000000（方便本地开发，短信没审核通过时用）
# 上线务必改 false
DEV_FAKE_SMS=true

# ── CORS 允许的前端地址（逗号分隔）──
# 本地开发填 vite 地址；上线填你的正式前端域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
